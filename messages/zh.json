    "general": [
      { "q": "PORTAL是什么？", "a": "PORTAL是一个将现场活动和演唱会体验数字化的平台。它在一个平台上提供活动发现、购票、社区互动和组织者工具。" },
      { "q": "使用PORTAL免费吗？", "a": "是的，活动发现、社区功能和购票对参与者完全免费。组织者有不同的定价方案。" },
      { "q": "你们在哪些城市运营？", "a": "目前我们在伊斯坦布尔、安卡拉、伊兹密尔、安塔利亚和布尔萨提供服务。我们计划很快扩展到更多城市。" }
    ],
    "tickets": [
      { "q": "如何使用门票？", "a": "购买的门票会以QR码形式显示在"我的门票"页面。只需在活动入口出示QR码即可。QR码会定期更新以确保安全。" },
      { "q": "可以退票吗？", "a": "活动前48小时内可以申请退票。退款可从"我的门票"页面发起，将在3-5个工作日内退回到您的支付方式。" },
      { "q": "可以将门票转让给他人吗？", "a": "可以，您可以使用"我的门票"页面上的转让按钮将活跃门票转让给另一位PORTAL用户。" }
    ],
    "organizers": [
      { "q": "如何成为组织者？", "a": "您可以从账户中申请成为组织者。申请审核通过后，即可访问组织者面板。您也可以用演示账户试用面板。" },
      { "q": "创建活动收费吗？", "a": "使用入门版方案每月可免费创建最多2场活动。更多活动请查看专业版或企业版方案。" },
      { "q": "推广系统是什么？", "a": "推广是帮助您的活动在平台上获得更多曝光的工具。包括首页推荐、搜索结果置顶和社区推荐等选项。" }
    ],
    "account": [
      { "q": "如何重置密码？", "a": "在登录页面点击"忘记密码"链接，即可收到发送到您邮箱的重置链接。" },
      { "q": "如何删除账户？", "a": "您可以在账户设置页面提交账户删除请求。提交后，您的数据将在30天内永久删除。" },
